# URL du backend Bookelo (sans slash final).
# Utilisez API_URL pour les appels serveur Next.js (recommandé).
# Inclure le préfixe /api (les routes sont /api/books, /api/categories, etc.)
API_URL=https://api.bookelo.tech/api

# Alternative : même URL exposée au navigateur (fetch côté client uniquement).
# NEXT_PUBLIC_API_URL=https://api.bookelo.tech/api

# Après modification : arrêtez puis relancez « npm run dev ».
